# Immich API base URL. Include /api, matching the Immich CLI convention.
IMMICH_URL=http://immich-server:2283/api

# Admin and WebDAV ports exposed by the app container.
ADMIN_PORT=8080
WEBDAV_PORT=8081

# Redis is used for shared cache state and DAV lock storage.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# DAV metadata cache and directory listing limits.
AUTH_CACHE_TTL_SECONDS=300
AUTH_FAILURE_LIMIT=10
AUTH_FAILURE_WINDOW_SECONDS=300
ALBUM_CACHE_TTL_SECONDS=60
SEARCH_CACHE_TTL_SECONDS=30
ASSET_CACHE_TTL_SECONDS=300
SEARCH_PAGE_SIZE=500
SEARCH_MAX_PAGES=20
ALBUM_FOLDER_SPLIT_THRESHOLD=200
DAY_FOLDER_SPLIT_THRESHOLD=1000

# DAV request hardening and backpressure.
WEBDAV_MAX_REQUEST_BODY_BYTES=1048576
WEBDAV_MAX_PATH_LENGTH=2048
WEBDAV_MAX_PATH_SEGMENTS=32
WEBDAV_MAX_CONCURRENT_REQUESTS=32
WEBDAV_MAX_CONCURRENT_STREAMS=8

# Local disk cache for bounded original-asset byte ranges.
BLOB_CACHE_ENABLED=true
BLOB_CACHE_DIR=/var/cache/immich-bridge/blob-cache
BLOB_CACHE_MAX_BYTES=1073741824
BLOB_CACHE_MAX_RANGE_BYTES=8388608
BLOB_CACHE_TTL_SECONDS=86400

LOG_LEVEL=INFO
LOG_FORMAT=console

# Enable noisy request/range/upstream stream metrics while debugging performance.
IMMICH_BRIDGE_METRICS=false
